# TIRA App Configuration
# Copy this file to .env and adjust values

# Server port (default: 5000)
PORT=5000

# Node environment
NODE_ENV=production

# PostgreSQL Database (optional - app works with in-memory JSON without this)
# If DATABASE_URL is set, app will use PostgreSQL for persistent storage
# If not set, app loads data from JSON files in ./data/ directory
DATABASE_URL=postgresql://tira:tira_secret_2024@postgres:5432/tira_db

# PostgreSQL container settings (for docker-compose)
POSTGRES_USER=tira
POSTGRES_PASSWORD=tira_secret_2024
POSTGRES_DB=tira_db
POSTGRES_PORT=5432
