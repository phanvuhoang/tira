# TIRA App Configuration
# Copy this file to .env and adjust values

# Server port (default: 5000)
PORT=5000

# Node environment
NODE_ENV=production

# AI API Keys (for report generation)
# Set at least one to enable AI report generation
ANTHROPIC_API_KEY=sk-ant-...your-key-here...
DEEPSEEK_API_KEY=sk-...your-key-here...

# PostgreSQL Database (optional - app works with in-memory JSON without this)
DATABASE_URL=postgresql://tira:tira_secret_2024@postgres:5432/tira_db

# PostgreSQL container settings (for docker-compose)
POSTGRES_USER=tira
POSTGRES_PASSWORD=tira_secret_2024
POSTGRES_DB=tira_db
POSTGRES_PORT=5432
